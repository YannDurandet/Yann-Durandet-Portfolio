---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/globals.css';
---

<BaseLayout
  title="Page Not Found — DRNDT Studio"
  description="The page you're looking for doesn't exist."
>
  <div class="min-h-screen bg-bg-primary flex items-center justify-center">
    <div class="text-center px-6">
      <div class="font-cascadia text-xs text-accent tracking-widest uppercase mb-6 flex items-center justify-center gap-2">
        <span class="w-2 h-2 border border-accent block"></span>
        [ ERROR: 404 ]
        <span class="w-8 h-[1px] bg-accent/50 block"></span>
      </div>

      <h1 class="text-text-primary mb-6 animate-fade-up">
        Page <span class="text-accent">Not Found</span>
      </h1>

      <p class="text-text-secondary mb-8 max-w-md mx-auto animate-fade-up" style="animation-delay: 0.2s">
        The summit you're looking for doesn't exist. Let's get you back on the trail.
      </p>

      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 bg-accent text-white rounded-md font-semibold hover:scale-105 active:scale-95 transition-all duration-300 animate-fade-up"
        style="animation-delay: 0.4s"
      >
        [ Back to Base Camp ]
      </a>
    </div>
  </div>
</BaseLayout>
